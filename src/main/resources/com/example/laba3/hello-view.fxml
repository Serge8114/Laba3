<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: #1a1e2b;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.laba3.HelloController">
    <center>
        <StackPane fx:id="imageContainer" style="-fx-background-color: #0f1219;" BorderPane.alignment="CENTER">
            <children>
                <ImageView fx:id="imageView" pickOnBounds="true" preserveRatio="true" StackPane.alignment="CENTER" />
            </children>
        </StackPane>
    </center>
    <bottom>
        <VBox alignment="CENTER" spacing="15.0" style="-fx-background-color: #252b3d;" BorderPane.alignment="CENTER">
            <children>
                <HBox alignment="CENTER" spacing="12.0">
                    <children>
                        <Button fx:id="btnFirst" style="-fx-background-color: #3d4b6a; -fx-text-fill: white; -fx-font-size: 20; -fx-font-weight: bold; -fx-background-radius: 12; -fx-padding: 12 20;" text="««" />
                        <Button fx:id="btnPrev" style="-fx-background-color: #4a5b7e; -fx-text-fill: white; -fx-font-size: 24; -fx-font-weight: bold; -fx-background-radius: 12; -fx-padding: 12 25;" text="«" />
                        <Button fx:id="btnPlay" style="-fx-background-color: #5d9b5d; -fx-text-fill: white; -fx-font-size: 20; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 12 30;" text="▶" />
                        <Button fx:id="btnNext" style="-fx-background-color: #4a5b7e; -fx-text-fill: white; -fx-font-size: 24; -fx-font-weight: bold; -fx-background-radius: 12; -fx-padding: 12 25;" text="»" />
                        <Button fx:id="btnLast" style="-fx-background-color: #3d4b6a; -fx-text-fill: white; -fx-font-size: 20; -fx-font-weight: bold; -fx-background-radius: 12; -fx-padding: 12 20;" text="»»" />
                        <Button fx:id="btnEffect" style="-fx-background-color: #b38b5d; -fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold; -fx-background-radius: 12; -fx-padding: 12 20;" text="⚡ Эффект" />
                    </children>
                </HBox>
                <HBox alignment="CENTER" spacing="25.0">
                    <children>
                        <Label fx:id="lblPosition" style="-fx-background-color: #2d3345; -fx-text-fill: #aab3cc; -fx-padding: 6 18; -fx-background-radius: 20;" text="0 из 0" />
                        <Label fx:id="lblFileName" style="-fx-text-fill: #e0e4f0;" text="нет картинки" />
                        <Label fx:id="lblFileInfo" style="-fx-text-fill: #8f9bb3;" text="" />
                        <Label fx:id="lblEffect" style="-fx-background-color: #b38b5d; -fx-text-fill: white; -fx-padding: 6 18; -fx-background-radius: 20;" text="Эффект: Вспышка" />
                    </children>
                </HBox>
            </children>
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
        </VBox>
    </bottom>
</BorderPane>